# Backend environment variables
NODE_ENV=development
PORT=5000

# MongoDB Atlas or local MongoDB URI
# Example local: mongodb://127.0.0.1:27017/restaurant
# Example atlas: mongodb+srv://<username>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority

# JWT settings
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRATION=1d
